generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  READ
  ASSIGN
  STATUS_CHANGE
}

enum OperationType {
  TASK
  WORK_ORDER
  INCIDENT
  INSPECTION
  SERVICE_REQUEST
}

enum OperationStatus {
  DRAFT
  PENDING
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
  WHATSAPP
}

enum AttachmentType {
  IMAGE
  DOCUMENT
  OTHER
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  legalName String?
  taxId     String?
  isActive  Boolean  @default(true)

  users         TenantUser[]
  roles         Role[]
  clients       Client[]
  operations    Operation[]
  notifications Notification[]
  attachments   Attachment[]
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String     @id @default(cuid())
  name     String
  email    String     @unique
  password String
  status   UserStatus @default(ACTIVE)

  memberships         TenantUser[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  uploadedAttachments Attachment[] @relation("UploadedAttachments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TenantUser {
  id       String @id @default(cuid())
  tenantId String
  userId   String
  roleId   String

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([roleId])
}

model Role {
  id          String  @id @default(cuid())
  tenantId    String?
  name        String
  description String?

  tenant      Tenant? @relation(fields: [tenantId], references: [id])
  users       TenantUser[]
  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  description String?

  roles RolePermission[]

  createdAt DateTime @default(now())
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model AuditLog {
  id       String  @id @default(cuid())
  tenantId String?
  userId   String?

  action   AuditAction
  module   String
  entity   String?
  entityId String?

  oldValue Json?
  newValue Json?
  metadata Json?

  ip        String?
  userAgent String?

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([module])
  @@index([entityId])
}

model Client {
  id       String @id @default(cuid())
  tenantId String

  name      String
  legalName String?
  taxId     String?
  email     String?
  phone     String?
  isActive  Boolean @default(true)

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  locations  ClientLocation[]
  contacts   ClientContact[]
  operations Operation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([name])
  @@index([taxId])
}

model ClientLocation {
  id       String @id @default(cuid())
  tenantId String
  clientId String

  name    String
  address String?
  city    String?
  state   String?
  country String?
  lat     Float?
  lng     Float?

  client Client @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([clientId])
}

model ClientContact {
  id       String @id @default(cuid())
  tenantId String
  clientId String

  name  String
  email String?
  phone String?
  role  String?

  client Client @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([clientId])
}

model Operation {
  id       String @id @default(cuid())
  tenantId String
  clientId String?

  type        OperationType
  title       String
  description String?
  status      OperationStatus @default(PENDING)
  priority    Priority        @default(MEDIUM)

  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  createdById  String
  assignedToId String?

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])

  assignments   OperationAssignment[]
  statusHistory OperationStatusHistory[]
  attachments   Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([clientId])
  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([createdById])
  @@index([assignedToId])
}

model OperationAssignment {
  id          String @id @default(cuid())
  tenantId    String
  operationId String
  userId      String

  operation Operation @relation(fields: [operationId], references: [id])

  createdAt DateTime @default(now())

  @@unique([operationId, userId])
  @@index([tenantId])
  @@index([operationId])
  @@index([userId])
}

model OperationStatusHistory {
  id          String @id @default(cuid())
  tenantId    String
  operationId String

  fromStatus  OperationStatus?
  toStatus    OperationStatus
  changedById String
  note        String?

  operation Operation @relation(fields: [operationId], references: [id])

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([operationId])
  @@index([changedById])
}

model Notification {
  id       String @id @default(cuid())
  tenantId String
  userId   String

  channel NotificationChannel @default(IN_APP)
  status  NotificationStatus @default(UNREAD)

  type    String
  title   String
  message String
  payload Json?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([type])
}

model Attachment {
  id       String @id @default(cuid())
  tenantId String

  operationId  String?
  uploadedById String

  type         AttachmentType @default(OTHER)
  originalName String
  fileName     String
  mimeType     String
  size         Int
  path         String
  url          String?
  description  String?
  metadata     Json?

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  operation  Operation? @relation(fields: [operationId], references: [id])
  uploadedBy User       @relation("UploadedAttachments", fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([operationId])
  @@index([uploadedById])
  @@index([type])
}